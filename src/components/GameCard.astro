---
export interface Props {
	title: string;
	slug: string;
	thumbnail: string;
	category: string;
}

const { title, slug, thumbnail, category } = Astro.props;
---

<a href={`/games/${slug}`} class="group relative block w-full aspect-square bg-[#1b1736] rounded-xl overflow-hidden shadow-md hover:shadow-2xl hover:-translate-y-1 transition-all focus:ring-4 focus:ring-indigo-500 border border-[#2d2856]">
	<img loading="lazy" src={thumbnail} class="absolute inset-0 w-full h-full object-cover" alt={`${title}`} />
	<!-- Gradient overly ONLY on hover for cleaner look like Poki -->
	<div class="absolute inset-0 bg-gradient-to-t from-gray-900 via-gray-900/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 z-10"></div>
	
	<div class="absolute bottom-0 left-0 w-full p-2 z-20 flex flex-col justify-end translate-y-full group-hover:translate-y-0 transition-transform duration-300 h-full">
		<h3 class="text-xs sm:text-sm font-bold text-white leading-tight drop-shadow-md bg-black/50 px-2 py-1 rounded w-max">{title}</h3>
	</div>
</a>
