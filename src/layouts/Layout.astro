---
import '../styles/global.css';
import games from '../data/games.json';

export interface Props {
	title: string;
	description?: string;
	image?: string;
	schemas?: string[];
}

const { 
	title, 
	description = "Play the absolute best HTML5 mobile and browser games for free on ZynfexGame without downloading anything.",
	image = "/og-image.jpg",
	schemas = []
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, 'https://zynfexgame.me');

// Prepare tiny search database for client
const searchDB = games.map(g => ({ title: g.title, slug: g.slug, thumbnail: g.thumbnail }));
---

<!DOCTYPE html>
<html lang="en" class="bg-[#242144] text-gray-100 antialiased font-sans">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		
		<!-- PWA Configuration -->
		<link rel="manifest" href="/manifest.json" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<meta name="theme-color" content="#16132b" />
		<script is:inline>
			if ('serviceWorker' in navigator) {
				window.addEventListener('load', () => {
					navigator.serviceWorker.register('/sw.js').catch((err) => console.error('PWA SW error:', err));
				});
			}
		</script>
		<link rel="canonical" href={`https://zynfexgame.me${Astro.url.pathname}${Astro.url.pathname.endsWith('/') ? '' : '/'}`} />
		<meta name="generator" content={Astro.generator} />
		
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />

		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL(image, canonicalURL)} />

		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalURL} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={new URL(image, canonicalURL)} />

		<!-- Google Analytics 4 -->
		<script is:inline>
			let thirdPartyLoaded = false;
			const loadThirdPartyScripts = () => {
				if (thirdPartyLoaded) return;
				thirdPartyLoaded = true;

				const gaScript = document.createElement('script');
				gaScript.src = "https://www.googletagmanager.com/gtag/js?id=G-YE82JXSRWN";
				gaScript.async = true;
				document.head.appendChild(gaScript);

				window.dataLayer = window.dataLayer || [];
				function gtag(){dataLayer.push(arguments);}
				gtag('js', new Date());
				gtag('config', 'G-YE82JXSRWN');
			};

			// Load instantly when user begins interacting with the page
			const interactEvents = ['scroll', 'mousemove', 'touchstart', 'click', 'keydown'];
			interactEvents.forEach(evt => {
				window.addEventListener(evt, loadThirdPartyScripts, { once: true, passive: true });
			});

			// Fallback: If no interaction, load anyway after a short grace period (4 seconds)
			setTimeout(loadThirdPartyScripts, 4000);
		</script>

		{schemas.map(schema => (
			<Fragment set:html={schema} />
		))}
	</head>
	<body class="flex flex-col min-h-screen bg-[#1c1938] text-gray-200 overflow-x-hidden relative">
		
		<!-- Sidebar Overlay (Hidden by default) -->
		<div id="sidebar-overlay" class="fixed inset-0 bg-black/60 z-[55] opacity-0 pointer-events-none transition-opacity duration-300"></div>

		<!-- Mobile Sidebar Drawer -->
		<aside id="sidebar" class="fixed inset-y-0 left-0 w-64 bg-[#16132b] shadow-2xl z-[60] transform -translate-x-full transition-transform duration-300 border-r border-[#2d2856] flex flex-col">
			<div class="h-16 flex items-center px-6 border-b border-[#2d2856]">
				<img src="/logo.png" alt="ZynfexGame Logo" class="h-8 w-auto rounded-md shadow-[0_0_10px_rgba(79,70,229,0.3)] mr-2" />
				<span class="font-extrabold text-xl tracking-tight text-white">ZynfexGame</span>
			</div>
			<div class="flex flex-col py-4 px-4 gap-2 flex-grow">
				<a href="/" class="py-2 px-3 rounded-lg hover:bg-[#2d2856] transition font-bold text-gray-300 hover:text-white">Home</a>
				<a href="/categories/" class="py-2 px-3 rounded-lg hover:bg-[#2d2856] transition font-bold text-gray-300 hover:text-white">All Categories</a>
				<a href="/blog/" class="py-2 px-3 rounded-lg hover:bg-[#2d2856] transition font-bold text-gray-300 hover:text-white">Gaming News</a>
				<hr class="border-[#2d2856] my-2" />
				<a href="/privacy-policy/" class="py-2 px-3 rounded-lg hover:bg-[#2d2856] transition font-bold text-sm text-gray-400 hover:text-gray-200">Privacy Policy</a>
				<a href="/terms/" class="py-2 px-3 rounded-lg hover:bg-[#2d2856] transition font-bold text-sm text-gray-400 hover:text-gray-200">Terms of Service</a>
				<a href="/disclaimer/" class="py-2 px-3 rounded-lg hover:bg-[#2d2856] transition font-bold text-sm text-gray-400 hover:text-gray-200">Disclaimer</a>
				<a href="/about/" class="py-2 px-3 rounded-lg hover:bg-[#2d2856] transition font-bold text-sm text-gray-400 hover:text-gray-200">About Us</a>
				<a href="/contact/" class="py-2 px-3 rounded-lg hover:bg-[#2d2856] transition font-bold text-sm text-indigo-400 hover:text-indigo-300">Contact Us</a>
			</div>
		</aside>

		<!-- Top Navigation Bar -->
		<header class="w-full h-16 bg-[#16132b] shadow-xl flex items-center justify-between px-4 lg:px-8 border-b border-[#2d2856] fixed top-0 left-0 z-50">
			<div class="flex items-center gap-6">
				<!-- Menu Icon -->
				<button id="menu-btn" aria-label="Open navigation menu" class="text-gray-400 hover:text-white transition focus:outline-none">
					<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" /></svg>
				</button>
				<!-- Brand -->
				<a href="/" class="flex items-center gap-2 group">
					<img src="/logo.png" alt="ZynfexGame Logo" class="h-9 w-auto rounded-md shadow-[0_0_15px_rgba(79,70,229,0.4)] group-hover:shadow-[0_0_20px_rgba(79,70,229,0.7)] transition-shadow duration-300" />
					<span class="font-extrabold text-2xl tracking-tight text-white hidden sm:block group-hover:text-indigo-400 transition-colors duration-300">ZynfexGame</span>
				</a>
			</div>
			
			<!-- Interactive Search Bar -->
			<div class="flex-grow max-w-xl mx-4 relative">
				<div class="relative w-full">
					<input id="search-input" type="text" placeholder="What you want to play?" class="w-full bg-[#0d0b1a] text-white rounded-full py-2.5 px-5 outline-none focus:ring-2 focus:ring-indigo-500 border border-[#2d2856] placeholder-gray-500 transition-all font-medium text-sm">
					<div class="absolute inset-y-0 right-0 pr-4 flex items-center pointer-events-none">
						<svg class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
					</div>
				</div>
				<!-- Search Results Dropdown -->
				<div id="search-results" class="absolute top-full left-0 w-full mt-2 bg-[#16132b] border border-[#2d2856] rounded-xl shadow-2xl hidden flex-col max-h-96 overflow-y-auto z-[70]">
					<!-- Results injected by JS -->
				</div>
			</div>

			<div class="flex items-center gap-4">
				<a href="/blog/" class="hidden md:flex text-gray-400 hover:text-white font-bold text-sm transition items-center gap-1">
					<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9.5a2.5 2.5 0 00-2.5-2.5H15M9 11l3 3m0 0l3-3m-3 3V8" /></svg>
					News
				</a>
			</div>
		</header>

		<!-- Main Page Content -->
		<main class="flex-grow w-full max-w-[1400px] mx-auto px-2 sm:px-4 md:px-8 pt-20 pb-8">
			<slot />
		</main>

		<!-- Global Footer -->
		<footer class="w-full bg-[#0d0b1a] border-t border-[#2d2856] py-10 mt-auto hidden md:block">
			<div class="max-w-[1400px] mx-auto px-4 md:px-8 flex flex-col md:flex-row justify-between items-center gap-4">
				<div class="text-gray-400 font-medium text-sm flex items-center gap-2">
					<span>⚡ ZynfexGame &copy; {new Date().getFullYear()}</span>
				</div>
				<div class="flex flex-wrap items-center gap-4 md:gap-6 justify-center">
					<a href="/contact/" class="text-indigo-400 hover:text-indigo-300 text-sm font-bold transition">Contact Us</a>
					<a href="/privacy-policy/" class="text-gray-400 hover:text-indigo-400 text-sm font-medium transition">Privacy Policy</a>
					<a href="/terms/" class="text-gray-400 hover:text-indigo-400 text-sm font-medium transition">Terms</a>
					<a href="/disclaimer/" class="text-gray-400 hover:text-indigo-400 text-sm font-medium transition">Disclaimer</a>
					<a href="/about/" class="text-gray-400 hover:text-indigo-400 text-sm font-medium transition">About Us</a>
					<a href="/blog/" class="text-gray-400 hover:text-indigo-400 text-sm font-medium transition">Blog</a>
				</div>
			</div>
		</footer>

		<!-- Mobile Bottom Navigation -->
		<nav class="fixed bottom-0 left-0 w-full h-16 bg-[#16132b] border-t border-[#2d2856] z-50 flex items-center justify-around md:hidden px-2 pb-safe shadow-2xl">
			<a href="/" class="flex flex-col items-center gap-1 text-indigo-400">
				<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor">
				  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
				</svg>
				<span class="text-xs font-bold">Home</span>
			</a>
			<a href="/categories/" class="flex flex-col items-center gap-1 text-gray-400 hover:text-gray-300">
				<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor">
				  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7" />
				</svg>
				<span class="text-xs font-bold">Categories</span>
			</a>
			<a href="/blog/" class="flex flex-col items-center gap-1 text-gray-400 hover:text-gray-300">
				<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor">
				  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9.5z" />
				</svg>
				<span class="text-xs font-bold">News</span>
			</a>
		</nav>

		<!-- Interactive Logic via Vanilla JS -->
		<script is:inline define:vars={{ searchDB }}>
			document.addEventListener("DOMContentLoaded", () => {
				// 1. Sidebar Toggle Logic
				const menuBtn = document.getElementById('menu-btn');
				const sidebar = document.getElementById('sidebar');
				const overlay = document.getElementById('sidebar-overlay');

				function toggleMenu() {
					const isOpen = sidebar.classList.contains('translate-x-0');
					if (isOpen) {
						sidebar.classList.remove('translate-x-0');
						sidebar.classList.add('-translate-x-full');
						overlay.classList.remove('opacity-100', 'pointer-events-auto');
						overlay.classList.add('opacity-0', 'pointer-events-none');
					} else {
						sidebar.classList.remove('-translate-x-full');
						sidebar.classList.add('translate-x-0');
						overlay.classList.remove('opacity-0', 'pointer-events-none');
						overlay.classList.add('opacity-100', 'pointer-events-auto');
					}
				}

				menuBtn.addEventListener('click', toggleMenu);
				overlay.addEventListener('click', toggleMenu);

				// 2. Search Logic
				const searchInput = document.getElementById('search-input');
				const searchResults = document.getElementById('search-results');

				searchInput.addEventListener('input', (e) => {
					const query = e.target.value.toLowerCase().trim();
					
					if (query.length < 2) {
						searchResults.classList.add('hidden');
						searchResults.classList.remove('flex');
						return;
					}

					// Filter DB
					const matched = searchDB.filter(game => game.title.toLowerCase().includes(query)).slice(0, 8); // Max 8 results

					if (matched.length > 0) {
						searchResults.innerHTML = matched.map(game => `
							<a href="/games/${game.slug}/" class="flex items-center gap-3 p-3 hover:bg-[#2d2856] transition border-b border-[#2d2856] last:border-0">
								<img src="${game.thumbnail}" alt="${game.title}" class="w-10 h-10 rounded object-cover" />
								<span class="text-white font-bold text-sm">${game.title}</span>
							</a>
						`).join('');
						searchResults.classList.remove('hidden');
						searchResults.classList.add('flex');
					} else {
						searchResults.innerHTML = `<div class="p-4 text-center text-sm text-gray-500 font-medium">No games found for "${query}"</div>`;
						searchResults.classList.remove('hidden');
						searchResults.classList.add('flex');
					}
				});

				// Hide search when clicking outside
				document.addEventListener('click', (e) => {
					if (!searchInput.contains(e.target) && !searchResults.contains(e.target)) {
						searchResults.classList.add('hidden');
						searchResults.classList.remove('flex');
					}
				});
			});
		</script>
	</body>
</html>
