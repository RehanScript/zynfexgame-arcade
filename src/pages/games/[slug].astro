---
import Layout from '../../layouts/Layout.astro';
import gamesData from '../../data/games.json';
import GameCard from '../../components/GameCard.astro';

export async function getStaticPaths() {
  return gamesData.map((game) => ({
    params: { slug: game.slug },
    props: { game },
  }));
}

const { game } = Astro.props;

// "More Games" logic: Filter out current game and randomize a bit
const otherGames = gamesData
	.filter(g => g.slug !== game.slug)
	.sort(() => Math.random() - 0.5)
	.slice(0, 12);
---

<Layout title={`${game.title} - Play Free Online | ZynfexGame`} description={game.description || `Play ${game.title} unblocked on ZynfexGame.`} image={game.thumbnail}>
	<!-- Breadcrumbs -->
	<nav class="flex text-xs text-gray-400 gap-2 mb-4 items-center overflow-x-auto whitespace-nowrap pb-2 no-scrollbar">
		<a href="/" class="hover:text-white transition">Home</a>
		<span>/</span>
		<a href={`/categories/${game.category.toLowerCase()}`} class="hover:text-white transition">{game.category} Games</a>
		<span>/</span>
		<span class="text-indigo-400 font-medium">{game.title}</span>
	</nav>

	<div class="flex flex-col lg:flex-row justify-between items-start gap-4 mb-6">
		<div>
			<h1 class="text-2xl md:text-3xl lg:text-4xl font-black text-white leading-tight">{game.title}</h1>
			<div class="flex items-center gap-4 mt-2">
				<div class="flex items-center gap-1 text-yellow-400 bg-yellow-400/10 px-2 py-0.5 rounded text-sm font-bold border border-yellow-400/20">
					<span>★</span>
					<span>{game.rating || "4.5"}</span>
				</div>
				<span class="text-gray-500 text-sm">{game.votes || "1.2K"} votes</span>
			</div>
		</div>
		
		<!-- Action Buttons -->
		<div class="flex gap-2 w-full lg:w-auto overflow-x-auto no-scrollbar pb-1">
			<button class="flex-1 lg:flex-none flex items-center justify-center gap-2 bg-[#1b1736] hover:bg-[#25204d] text-gray-300 px-4 py-2.5 rounded-xl border border-gray-800 transition shadow-sm group">
				<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-active:scale-90 transition" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>
				<span class="text-sm font-bold">Favorite</span>
			</button>
			<button class="flex-1 lg:flex-none flex items-center justify-center gap-2 bg-[#1b1736] hover:bg-[#25204d] text-gray-300 px-4 py-2.5 rounded-xl border border-gray-800 transition shadow-sm">
				<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" /></svg>
				<span class="text-sm font-bold">Share</span>
			</button>
		</div>
	</div>

	<!-- Main Game Section (Full Width Player) -->
	<section class="relative mb-8 group">
		<div class="aspect-video w-full h-[60vh] md:h-[80vh] bg-black rounded-3xl overflow-hidden shadow-[0_20px_50px_rgba(0,0,0,0.5)] border-4 border-[#1b1736] relative" id="game-container">
			<iframe 
				id="game-iframe"
				src={game.iframe}
				class="w-full h-full border-0"
				title={game.title}
				allow="autoplay; fullscreen; focus; pointer-lock; microphone; clipboard-write"
				loading="eager">
			</iframe>
			
			<!-- Fullscreen Toggle Overlay (Shows on hover) -->
			<div class="absolute bottom-4 right-4 z-40">
				<button id="fullscreen-btn" class="bg-indigo-600/90 hover:bg-indigo-500 backdrop-blur-md text-white px-5 py-2.5 rounded-2xl flex items-center gap-2 transition shadow-2xl border border-white/10 font-bold active:scale-95">
					<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4" /></svg>
					<span>Fullscreen</span>
				</button>
			</div>
		</div>
	</section>



	<!-- Two-column Layout -->
	<div class="grid grid-cols-1 lg:grid-cols-[1fr_350px] gap-10 lg:gap-16">
		
		<!-- Left Column: Rich Content -->
		<div class="flex flex-col gap-10">
			
			<!-- Game Info Card -->
			<div class="grid grid-cols-2 sm:grid-cols-4 gap-4 bg-[#0f0c24] p-6 rounded-3xl border border-[#231f47] shadow-xl">
				<div class="flex flex-col gap-1">
					<span class="text-gray-500 text-xs font-bold uppercase tracking-widest">Rating</span>
					<span class="text-white font-black text-lg">{game.rating || "4.5"}/5</span>
				</div>
				<div class="flex flex-col gap-1 border-l border-gray-800 pl-4">
					<span class="text-gray-500 text-xs font-bold uppercase tracking-widest">Plays</span>
					<span class="text-white font-black text-lg">{game.views || "1.2M"}</span>
				</div>
				<div class="flex flex-col gap-1 border-l border-gray-800 pl-4">
					<span class="text-gray-500 text-xs font-bold uppercase tracking-widest">Released</span>
					<span class="text-white font-black text-lg">{game.released || "2024"}</span>
				</div>
				<div class="flex flex-col gap-1 border-l border-gray-800 pl-4">
					<span class="text-gray-500 text-xs font-bold uppercase tracking-widest">Technology</span>
					<span class="text-white font-black text-lg">{game.technology || "HTML5"}</span>
				</div>
			</div>

			<!-- Tags Section -->
			<div class="flex flex-wrap gap-2">
				<h3 class="w-full text-xs font-black text-gray-500 uppercase tracking-widest mb-2 flex items-center gap-2">
					<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" /></svg>
					Tagged in
				</h3>
				{(game.tags || [game.category, "Unblocked", "IO Game"]).map(tag => (
					<a href={`/categories/${tag.toLowerCase()}`} class="bg-[#1b1736] hover:bg-indigo-600/20 text-indigo-400 px-4 py-2 rounded-xl text-sm font-bold border border-gray-800 transition-all hover:-translate-y-0.5 whitespace-nowrap">
						#{tag}
					</a>
				))}
			</div>

			<!-- Long Description -->
			<article class="prose prose-invert max-w-none">
				<h2 class="text-2xl font-black text-white mb-4">{game.title}: The Ultimate Online Experience</h2>
				<p class="text-gray-300 leading-relaxed text-lg italic border-l-4 border-indigo-500 pl-4 bg-indigo-500/5 py-4 rounded-r-xl">
					{game.description || `Experience the thrill of ${game.title} unblocked on ZynfexGame. No downloads, no installs—just pure, instant fun.`}
				</p>

				<!-- Editor Review Section (High Value Content) -->
				{game.editorReview && (
					<div class="bg-indigo-600/5 border-l-4 border-indigo-500 p-8 rounded-r-3xl my-10 shadow-inner">
						<h3 class="text-xl font-black text-white mb-4 flex items-center gap-3">
							<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-indigo-400 font-bold" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
							Collector's Choice: Editor's Review
						</h3>
						<p class="text-gray-300 leading-relaxed text-base italic">
							"{game.editorReview}"
						</p>
					</div>
				)}
				
				<div class="mt-8">
					<h3 class="text-xl font-black text-white mb-6 flex items-center gap-3">
						<span class="w-2 h-8 bg-indigo-500 rounded-full"></span>
						How to Play {game.title}
					</h3>
					<p class="text-gray-400 mb-6">
						<strong>Your mission:</strong> {game.mission || `Master the mechanics of ${game.title} and outsmart your opponents to climb the leaderboard.`}
					</p>
					
					<div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
						<div class="bg-[#0d0b1a] p-6 rounded-3xl border border-gray-800">
							<h4 class="text-indigo-400 font-bold mb-4 flex items-center gap-2">
								<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" /></svg>
								Key Strategies
							</h4>
							<ul class="space-y-3">
								{(game.strategies || ["Study the map", "Collect power-ups", "Stay mobile", "Practice makes perfect"]).map(strat => (
									<li class="flex gap-3 text-sm text-gray-400 items-start">
										<span class="text-indigo-500 font-bold">•</span>
										<span>{strat}</span>
									</li>
								))}
							</ul>
						</div>

						<div class="bg-[#0d0b1a] p-6 rounded-3xl border border-gray-800">
							<h4 class="text-indigo-400 font-bold mb-4 flex items-center gap-2">
								<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" /></svg>
								Controls
							</h4>
							<div class="space-y-4">
								<div>
									<span class="text-[10px] font-black uppercase text-gray-600 tracking-[0.2em] block mb-2">Desktop / PC</span>
									<p class="text-sm text-gray-300" set:html={game.controls?.pc || game.instructions}></p>
								</div>
								<div>
									<span class="text-[10px] font-black uppercase text-gray-600 tracking-[0.2em] block mb-2">Mobile / Touch</span>
									<p class="text-sm text-gray-300">{game.controls?.mobile || "Simply tap or swipe to interact with the game elements."}</p>
								</div>
							</div>
						</div>
					</div>

					<!-- Beginner Guide Promo (Conditional) -->
					{(game.slug === 'shell-shockers' || game.slug === 'smash-karts' || game.slug === 'geometry-dash-lite' || game.slug === 'paper-io' || game.slug === 'starblast-io' || game.slug === 'sea-dragons' || game.slug === 'wormszone-io' || game.slug === 'stabfish-io') && (
						<div class="bg-gradient-to-r from-indigo-900/40 to-[#1b1736] p-8 rounded-3xl border border-indigo-500/30 mb-8 flex flex-col sm:flex-row items-center gap-6 shadow-2xl overflow-hidden relative group">
							<div class="absolute -right-10 -top-10 w-40 h-40 bg-indigo-500/10 blur-[50px] rounded-full group-hover:bg-indigo-500/20 transition-all duration-700"></div>
							<div>
								<h4 class="text-xl font-black text-white mb-2">Want to win every match?</h4>
								<p class="text-gray-400 text-sm mb-4">Read our exclusive 2026 beginner's guide for {game.title} and dominate the competition.</p>
								<a href={`/blog/how-to-play-${game.slug}`} class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-500 text-white font-bold px-6 py-2.5 rounded-xl transition-all shadow-lg active:scale-95">
									<span>Take the Guide</span>
									<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
								</a>
							</div>
						</div>
					)}

					<h3 class="text-xl font-black text-white mb-6 flex items-center gap-3">
						<span class="w-2 h-8 bg-indigo-500 rounded-full"></span>
						Tips & Tricks for Mastery
					</h3>
					<ul class="space-y-4 mb-10">
						{(game.proTips || ["Use headphones for better rhythm", "Practice in short sessions", "Watch top players on YouTube"]).map(tip => (
							<li class="flex gap-4 p-4 bg-[#0d0b1a] rounded-2xl border border-gray-800 hover:border-indigo-500/30 transition-colors group">
								<div class="w-10 h-10 shrink-0 bg-indigo-500/10 rounded-xl flex items-center justify-center text-indigo-400 group-hover:scale-110 transition-transform">
									<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
								</div>
								<p class="text-gray-400 text-sm leading-relaxed self-center">{tip}</p>
							</li>
						))}
					</ul>
				</div>
			</article>

			<!-- Specific Game FAQ -->
			<section class="max-w-none w-full pb-20">
				<h2 class="text-2xl font-black text-white mb-8 border-b border-gray-800 pb-4 flex items-center gap-3">
					<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
					{game.title} FAQs
				</h2>
				<div class="space-y-4">
					{(game.faq || [
						{q: `Is ${game.title} free to play?`, a: `Yes, ${game.title} is completely free and can be played directly in your browser without any downloads.`},
						{q: `Can I play ${game.title} unblocked?`, a: `Yes, ZynfexGame provides unblocked access to ${game.title} for schools and offices.`}
					]).map((item, i) => (
						<details class="group bg-[#0f0c24] rounded-2xl border border-[#231f47] overflow-hidden" open={i===0}>
							<summary class="font-bold text-white p-5 cursor-pointer list-none flex justify-between items-center group-open:bg-indigo-600/10 transition-colors">
								<span>{item.q}</span>
								<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-indigo-400 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
							</summary>
							<div class="p-5 text-gray-400 text-sm leading-relaxed border-t border-[#231f47]">
								{item.a}
							</div>
						</details>
					))}
				</div>
			</section>

		</div>

		<!-- Right Column: Sidebar descubery -->
		<aside class="flex flex-col gap-8">
			
			<div class="bg-[#0f0c24] p-6 rounded-3xl border border-[#231f47] shadow-2xl sticky top-24">
				<h3 class="text-xl font-black text-white mb-6 flex items-center justify-between">
					<span>More Games</span>
					<span class="text-indigo-500">🔥</span>
				</h3>
				<div class="grid grid-cols-2 min-[400px]:grid-cols-3 lg:grid-cols-2 gap-4">
					{otherGames.map(g => (
						<div class="transition-all hover:scale-105">
							<a href={`/games/${g.slug}`} class="block aspect-square rounded-xl overflow-hidden border border-gray-800 shadow-lg relative group">
								<img src={g.thumbnail} alt={g.title} class="w-full h-full object-cover" loading="lazy" />
								<div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center p-2 text-center text-[10px] font-black text-white uppercase tracking-wider">{g.title}</div>
							</a>
						</div>
					))}
				</div>
				<a href="/" class="mt-8 block bg-indigo-600 hover:bg-indigo-500 text-white text-center font-black py-4 rounded-2xl transition-all shadow-xl text-sm uppercase tracking-widest">
					Explore All Games
				</a>


			</div>
		</aside>

	</div>

	<!-- AdBlock Toast logic included in Layout/Global usually, keeping it here for continuity if not -->
</Layout>

<script>
	document.addEventListener('DOMContentLoaded', () => {
		const btn = document.getElementById('fullscreen-btn');
		const container = document.getElementById('game-container');
		
		btn?.addEventListener('click', () => {
			if (!document.fullscreenElement) {
				container?.requestFullscreen().catch(err => {
					console.error(`Error attempting to enable fullscreen: ${err.message}`);
				});
			} else {
				document.exitFullscreen();
			}
		});

		// Prevent spacebar & arrow keys from scrolling
		const gameKeys = ['Space', 'ArrowUp', 'ArrowDown', 'ArrowLeft', 'ArrowRight'];
		const gameContainer = document.getElementById('game-container');

		window.addEventListener('keydown', (e) => {
			if (gameKeys.includes(e.code)) {
				if (gameContainer) {
					const rect = gameContainer.getBoundingClientRect();
					const inView = rect.top < window.innerHeight && rect.bottom > 0;
					if (inView) {
						e.preventDefault();
					}
				}
			}
		}, { passive: false });
	});
</script>

<style>
.no-scrollbar::-webkit-scrollbar { display: none; }
.no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>
