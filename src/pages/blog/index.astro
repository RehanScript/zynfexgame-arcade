---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<Layout title="ZynfexGame Blog - Gaming News & Guides">
	<div class="flex flex-col gap-6">
		<section>
			<h1 class="text-3xl font-extrabold text-white mb-2">Gaming <span class="text-indigo-400">News & Guides</span></h1>
			<p class="text-gray-400 mb-8">Stay updated with the latest in the casual gaming world.</p>
			
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
				{sortedPosts.map(post => (
					<a href={`/blog/${post.id}/`} class="bg-gray-800 rounded-2xl overflow-hidden border border-gray-700 hover:border-indigo-500 transition-colors group flex flex-col h-full shadow-lg">
						{post.data.image ? (
							<img src={post.data.image} alt={post.data.title} class="w-full h-48 object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
						) : (
							<div class="w-full h-48 bg-gradient-to-br from-indigo-900 to-purple-900 flex items-center justify-center">
								<span class="text-4xl">🎮</span>
							</div>
						)}
						<div class="p-5 flex flex-col flex-grow">
							<div class="flex items-center gap-2 mb-3">
								<span class="text-xs font-semibold px-2 py-1 bg-gray-900 text-indigo-400 rounded-md">News</span>
								<span class="text-xs text-gray-500">{post.data.publishDate.toLocaleDateString()}</span>
							</div>
							<h2 class="text-xl font-bold text-white mb-2 leading-tight group-hover:text-indigo-300 transition-colors">{post.data.title}</h2>
							<p class="text-sm text-gray-400 line-clamp-3 mb-4">{post.data.description}</p>
							<span class="mt-auto text-indigo-400 text-sm font-bold flex items-center gap-1 group-hover:gap-2 transition-all">
								Read Article &rarr;
							</span>
						</div>
					</a>
				))}
			</div>
		</section>
	</div>
</Layout>
