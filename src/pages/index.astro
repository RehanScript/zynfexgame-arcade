---
import Layout from '../layouts/Layout.astro';
import GameCard from '../components/GameCard.astro';
import games from '../data/games.json';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

// Simple deduplication for categories to build the top carousel
const categorySet = new Set(games.map(g => g.category));
const uniqueCategories = Array.from(categorySet).slice(0, 8); 

// Filter mobile-friendly games for the new section
const mobileGames = games.filter(g => g.mobileFriendly).slice(0, 12);

// Editor's Picks (Curated sections)
const strategistGames = games.filter(g => g.category === 'Strategy' || g.category === 'Puzzle').slice(0, 4);
const actionGames = games.filter(g => g.category === 'Action' || g.category === 'Arcade').slice(0, 4);

// Trending games pagination logic: Group games into sets of 21
const trendingGames = games;
const CHUNK_SIZE = 21;
const gameChunks = [];
for (let i = 0; i < trendingGames.length; i += CHUNK_SIZE) {
	gameChunks.push(trendingGames.slice(i, i + CHUNK_SIZE));
}

// Initial visibility threshold: 3 sections (63 games)
const INITIAL_SECTION_LIMIT = 3;

// Fetch Blog Posts for the new section
const blogPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
---

<Layout title="ZynfexGame | Play HTML5 Online Games Free - No Downloads">
	<div class="flex flex-col gap-10 md:gap-16">
		
		<!-- Mobile Friendly Section (High Visibility) -->
		<section class="relative">
			<div class="flex justify-between items-center mb-6">
				<h2 class="text-xl md:text-2xl font-black flex items-center gap-2 text-white">
					<span class="bg-indigo-600 p-1.5 rounded-lg">📱</span> Mobile Friendly Games
				</h2>
				<a href="/categories/mobile-friendly" class="text-xs font-bold text-indigo-400 hover:text-indigo-300 transition-colors uppercase tracking-widest">See All</a>
			</div>
			<div class="flex overflow-x-auto pb-4 gap-4 no-scrollbar -mx-1 px-1">
				{mobileGames.map(game => (
					<div class="flex-shrink-0 w-32 sm:w-40 md:w-48">
						<GameCard 
							title={game.title} 
							slug={game.slug} 
							category={game.category} 
							thumbnail={game.thumbnail} 
							mobileFriendly={game.mobileFriendly}
						/>
					</div>
				))}
			</div>
		</section>

		<!-- Category Horizontal Scroller -->
		<section>
			<h2 class="text-lg md:text-xl font-extrabold flex items-center gap-2 mb-6 text-gray-300">
				<span class="text-orange-400">🔥</span> Cool Categories
			</h2>
			<div class="flex overflow-x-auto pb-4 gap-3 md:gap-4 no-scrollbar">
				{uniqueCategories.map(cat => (
					<a href={`/categories/${cat.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`} class="flex-shrink-0 w-32 md:w-40 aspect-[2/1] rounded-xl bg-gradient-to-br from-[#2b2553] to-[#1c1938] border border-[#3b346e] flex flex-col items-center justify-center hover:scale-105 transition-transform group cursor-pointer shadow-lg">
						<span class="text-white font-bold text-sm tracking-wide">{cat}</span>
					</a>
				))}
			</div>
		</section>

		<!-- Main Trending Games Sections -->
		<section id="trending-container">
			<h2 class="text-xl md:text-2xl font-black flex items-center gap-3 mb-8 text-white border-l-4 border-indigo-500 pl-4">
				Trending Games
				<span class="text-xs md:text-sm font-medium text-gray-500 bg-gray-800/50 px-3 py-1 rounded-full whitespace-nowrap">Play fresh online games picked for you!</span>
			</h2>
			
			<div id="game-sections-wrapper" class="space-y-12">
				{gameChunks.map((chunk, chunkIndex) => {
					const isHidden = chunkIndex >= INITIAL_SECTION_LIMIT;
					return (
						<div class={`js-game-section ${isHidden ? 'hidden' : ''}`}>
							<div class="grid grid-cols-3 min-[400px]:grid-cols-4 sm:grid-cols-5 md:grid-cols-6 lg:grid-cols-7 xl:grid-cols-8 gap-3 sm:gap-4">
								{chunk.map((game, gameIndex) => (
									<div key={game.slug}>
										<GameCard 
											title={game.title} 
											slug={game.slug} 
											category={game.category} 
											thumbnail={game.thumbnail} 
											mobileFriendly={game.mobileFriendly} 
											lazy={(chunkIndex * CHUNK_SIZE + gameIndex) >= 12} 
										/>
									</div>
								))}
							</div>
						</div>
					)
				})}
			</div>

			<!-- Load More Footer -->
			{gameChunks.length > INITIAL_SECTION_LIMIT && (
				<div class="mt-12 flex justify-center">
					<button id="load-more-btn" class="bg-indigo-600 hover:bg-indigo-500 text-white font-black py-4 px-12 rounded-2xl transition-all shadow-2xl hover:shadow-indigo-500/20 active:scale-95 text-sm uppercase tracking-widest flex items-center gap-3">
						<span>More Games</span>
						<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7" /></svg>
					</button>
				</div>
			)}
		</section>

		<!-- Blog Section: Strategy Guides & Tips -->
		<section class="mt-10">
			<div class="flex justify-between items-center mb-8 border-l-4 border-indigo-500 pl-4">
				<h2 class="text-xl md:text-2xl font-black text-white">Latest Strategy Guides & Tips</h2>
				<a href="/blog" class="text-xs font-bold text-indigo-400 hover:text-indigo-300 transition-colors uppercase tracking-widest flex items-center gap-1">
					View All 
					<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
				</a>
			</div>
			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
				{blogPosts.map(post => (
					<a href={`/blog/${post.id}`} class="bg-[#0f0c24] rounded-2xl border border-[#231f47] overflow-hidden hover:border-indigo-500/50 transition-all group shadow-lg flex flex-col">
						{post.data.image && (
							<div class="aspect-video overflow-hidden">
								<img src={post.data.image} alt={post.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
							</div>
						)}
						<div class="p-5 flex flex-col flex-grow">
							<div class="flex items-center gap-2 mb-3">
								<span class="text-[10px] font-black uppercase tracking-widest text-indigo-400 bg-indigo-500/10 px-2 py-0.5 rounded-md">Guide</span>
								<span class="text-[10px] font-bold text-gray-500 uppercase tracking-widest">{post.data.publishDate.toLocaleDateString()}</span>
							</div>
							<h3 class="text-white font-bold text-base line-clamp-2 leading-snug group-hover:text-indigo-400 transition-colors">{post.data.title}</h3>
						</div>
					</a>
				))}
			</div>
		</section>

		<!-- Why Players Choose Section (Gamezop inspired) -->
		<section class="bg-[#0f0c24] rounded-3xl p-8 md:p-12 border border-[#231f47] shadow-2xl">
			<div class="max-w-4xl mx-auto">
				<h2 class="text-2xl md:text-3xl font-black text-white mb-4 text-center">Play Free Online Games Instantly on ZynfexGame</h2>
				<p class="text-gray-400 text-center mb-12 leading-relaxed">Enjoy hundreds of free online games on ZynfexGame that load instantly in your browser. Skip app store downloads and endless installs—just tap and start playing anytime, anywhere.</p>
				
				<div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12">
					<div>
						<h3 class="text-xl font-bold text-indigo-400 mb-6 flex items-center gap-2">
							<span class="w-2 h-6 bg-indigo-500 rounded-full"></span>
							Why Players Choose ZynfexGame?
						</h3>
						<ul class="space-y-4">
							{[
								{t: "Curated Library", d: "Every game is hand-picked for fun and replay value."},
								{t: "Instant Access", d: "No downloads, patches, or updates required."},
								{t: "Zero Storage Usage", d: "All games run directly in your browser."},
								{t: "Secure & Family-Friendly", d: "Privacy-focused and safe for all ages."},
								{t: "Cross-Device Tested", d: "Seamless play on phones, tablets, and desktops."}
							].map(item => (
								<li class="flex gap-3">
									<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-green-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" /></svg>
									<div>
										<span class="text-white font-bold block leading-none mb-1">{item.t}</span>
										<span class="text-gray-500 text-sm leading-tight">{item.d}</span>
									</div>
								</li>
							))}
						</ul>
					</div>

					<!-- Editor's Picks -->
					<div>
						<h3 class="text-xl font-bold text-indigo-400 mb-6 flex items-center gap-2">
							<span class="w-2 h-6 bg-indigo-500 rounded-full"></span>
							Editor’s Picks
						</h3>
						<div class="space-y-6">
							<div>
								<h4 class="text-sm font-black text-gray-500 uppercase tracking-widest mb-3">Strategists & Thinkers</h4>
								<div class="flex flex-wrap gap-2">
									{strategistGames.map(game => (
										<a href={`/games/${game.slug}`} class="bg-[#1b1736] hover:bg-[#25204d] text-gray-300 hover:text-white px-3 py-1.5 rounded-lg text-xs font-bold transition-colors border border-gray-800">{game.title}</a>
									))}
								</div>
							</div>
							<div>
								<h4 class="text-sm font-black text-gray-500 uppercase tracking-widest mb-3">Action & Thrill Seekers</h4>
								<div class="flex flex-wrap gap-2">
									{actionGames.map(game => (
										<a href={`/games/${game.slug}`} class="bg-[#1b1736] hover:bg-[#25204d] text-gray-300 hover:text-white px-3 py-1.5 rounded-lg text-xs font-bold transition-colors border border-gray-800">{game.title}</a>
									))}
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- SEO FAQ Section -->
		<section class="max-w-3xl mx-auto w-full pb-20">
			<h2 class="text-2xl font-black text-white mb-8 border-b border-gray-800 pb-4">Frequently Asked Questions</h2>
			<div class="space-y-4">
				{[
					{q: "What are the best free games on ZynfexGame?", a: "Some of our featured and community-favorite titles include Smash Karts, Shell Shockers, and Count Masters. We curate our library to ensure only high-quality games are provided."},
					{q: "Which games can I play online on my phone?", a: "Most of our games are mobile-optimized! Look for the 📱 badge on game cards. Titles like Splix.io, Karate Bros, and Doodle Jump work perfectly on mobile browsers."},
					{q: "Can I play free games without installing anything?", a: "Yes. All ZynfexGame titles run directly inside your browser (Chrome, Safari, Edge, or Brave), so there are no downloads or installations required."},
					{q: "Do I need to register to play?", a: "No registration or sign-up is needed. Just open any game and start playing instantly with zero friction."},
					{q: "Is ZynfexGame safe to use?", a: "Yes. Browser-based gameplay eliminates download-related risks. We follow strict security best practices to protect your privacy and device safety."}
				].map((faq, i) => (
					<details class="group bg-[#0f0c24] rounded-2xl border border-[#231f47] overflow-hidden" open={i===0}>
						<summary class="font-bold text-white p-5 cursor-pointer list-none flex justify-between items-center group-open:bg-indigo-600/10 transition-colors">
							<span>{faq.q}</span>
							<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-indigo-400 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
						</summary>
						<div class="p-5 text-gray-400 text-sm leading-relaxed border-t border-[#231f47]">
							{faq.a}
						</div>
					</details>
				))}
			</div>
		</section>

	</div>

	<!-- Client Side Pagination Script -->
	<script is:inline>
		document.addEventListener("DOMContentLoaded", () => {
			const loadMoreBtn = document.getElementById('load-more-btn');
			
			if (loadMoreBtn) {
				loadMoreBtn.addEventListener('click', () => {
					const nextHiddenSection = document.querySelector('.js-game-section.hidden');
					if (nextHiddenSection) {
						nextHiddenSection.classList.remove('hidden');
					}
					
					// Check if any hidden sections remain
					const remainingHidden = document.querySelectorAll('.js-game-section.hidden');
					if (remainingHidden.length === 0) {
						loadMoreBtn.style.display = 'none';
					}
				});
			}
		});
	</script>
</Layout>

<style>
.no-scrollbar::-webkit-scrollbar { display: none; }
.no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>
